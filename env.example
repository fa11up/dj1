# Spotify API Credentials
# Get these from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/callback

# Anthropic API — required when brain.provider: anthropic (default)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Local / OpenAI-compatible brain — required when brain.provider: openai_compatible
# Ollama needs any non-empty value; llama.cpp server is fine with "none"
BRAIN_API_KEY=ollama